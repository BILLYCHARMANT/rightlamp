# =============================================================================
# PV-GRID — environment template
# Copy to `.env.local` for Next.js + copy DATABASE_URL into `.env` if you prefer
# the Prisma CLI reading only `.env` (we load both in prisma.config.ts).
# =============================================================================

# Public site URL (used in emails, OG URLs, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# NextAuth (staff login → /login, protects /dashboard)
# -----------------------------------------------------------------------------
# Generate NEXTAUTH_SECRET: openssl rand -base64 32
# Vercel: set NEXTAUTH_URL to your production domain (e.g. https://your-app.vercel.app)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Storefront catalog (optional)
# -----------------------------------------------------------------------------
# Defaults to https://www.rightlamps.com — override to stage another API origin.
# RIGHTLAMPS_API_ORIGIN=https://www.rightlamps.com
# Optional: forward session for protected admin APIs (expense, report summary).
# RIGHTLAMPS_API_COOKIE=connect.sid=...; other=cookies
# RIGHTLAMPS_API_TOKEN=

# -----------------------------------------------------------------------------
# Railway PostgreSQL
# -----------------------------------------------------------------------------
# In Railway: create a Postgres plugin → Variables tab exposes DATABASE_URL.
# Use the **public** / external URL string when connecting from your laptop.
# Inside Railway's same project, the default DATABASE_URL often uses private hostnames.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# If Railway ever exposes separate pooled vs direct URLs, Prisma migrations sometimes need:
# DIRECT_URL="postgresql://..."

# -----------------------------------------------------------------------------
# First admin user (npm run db:seed — upserts into DB)
# -----------------------------------------------------------------------------
# SEED_ADMIN_EMAIL=admin@pv-grid.rw
# SEED_ADMIN_PASSWORD=choose-a-strong-password

# -----------------------------------------------------------------------------
# Payments / email / storage (later)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# RESEND_API_KEY=
