// Rightlamps — PostgreSQL on Railway (via DATABASE_URL in prisma.config.ts)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StaffRole {
  ADMIN
  STAFF
}

/// Why shelf quantity changed — aligns Stock-In / Stock-Out / History tabs with append-only ledger.
enum StockMovementReason {
  RECEIPT
  WASTE
  TRANSFER
  ADJUSTMENT
  OTHER
}

/// Dashboard access — credentials via NextAuth (see `src/lib/auth.ts`).
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String
  role         StaffRole @default(STAFF)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
}

/// Sellable item shown on the storefront when `published` is true.
model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  /** Optional merchandising bucket — set when creating a SKU in staff UI. */
  category    String?  @db.VarChar(160)
  description String?  @db.Text
  priceCents  Int
  currency    String   @default("TZS")
  stock       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stockMovements StockMovement[]

  @@index([published])
}

/// Append-only movements — Rightlamps keeps qty on product; ledger captures receipts/removals for ops tabs + audit.
model StockMovement {
  id             String              @id @default(cuid())
  productId      String
  delta          Int
  reason         StockMovementReason @default(OTHER)
  note           String?             @db.VarChar(2000)
  receiptStatus  String?             @db.VarChar(32)
  createdAt      DateTime            @default(now())
  createdByEmail String?             @db.VarChar(255)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}
